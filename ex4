package com.example.kamarajcollege4;
import android.database.Cursor;
import android.database.sqlite.SQLiteDatabase;
import android.os.Bundle;
import android.widget.*;
import androidx.appcompat.app.AppCompatActivity;
public class MainActivity2 extends AppCompatActivity {
    TextView tName, tDept, tYear, tDob, tGender, tEvent;
    Button bFirst, bLast, bNext, bPrevious,bBack;

    SQLiteDatabase db;
    Cursor c;

    @Override
    protected void onCreate(Bundle savedInstanceState) {
        super.onCreate(savedInstanceState);
        setContentView(R.layout.activity_main2);

        tName = findViewById(R.id.tName);
        tDept = findViewById(R.id.tDept);
        tYear = findViewById(R.id.tYear);
        tDob = findViewById(R.id.tDob);
        tGender = findViewById(R.id.tGender);
        tEvent = findViewById(R.id.tEvent);

        bFirst = findViewById(R.id.b1);
        bLast = findViewById(R.id.b2);
        bNext = findViewById(R.id.b3);
        bPrevious = findViewById(R.id.b4);
        bBack = findViewById(R.id.button);

        db = openOrCreateDatabase("KamarajCollegeDB", MODE_PRIVATE, null);

        c = db.rawQuery("SELECT * FROM event", null);

        if (c.getCount() == 0) {
            Toast.makeText(this, "No Records Found", Toast.LENGTH_SHORT).show();
            return;
        }

        c.moveToFirst();
        showRecord();

        bFirst.setOnClickListener(v -> {
            c.moveToFirst();
            showRecord();
        });

        bLast.setOnClickListener(v -> {
            c.moveToLast();
            showRecord();
        });

        bNext.setOnClickListener(v -> {
            if (c.moveToNext()) {
                showRecord();
            } else {
                c.moveToLast();
                Toast.makeText(this, "Last Record", Toast.LENGTH_SHORT).show();
            }
        });

        bPrevious.setOnClickListener(v -> {
            if (c.moveToPrevious()) {
                showRecord();
            } else {
                c.moveToFirst();
                Toast.makeText(this, "First Record", Toast.LENGTH_SHORT).show();
            }
        });
        bBack.setOnClickListener(v -> finish());
    }

    private void showRecord() {

        tName.setText("Name: " + c.getString(0));
        tDept.setText("Department: " + c.getString(1));
        tYear.setText("Year: " + c.getString(2));
        tDob.setText("DOB: " + c.getString(3));
        tGender.setText("Gender: " + c.getString(4));
        tEvent.setText("Event: " + c.getString(5));
    }
}
